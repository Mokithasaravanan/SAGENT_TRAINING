{
  "info": {
    "name": "NGO Donation Management API",
    "description": "Complete Postman collection for the NGO Donation Management backend.",
    "_postman_id": "ngo-donation-api-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "",                     "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\",\n  \"address\": \"Chennai, Tamil Nadu\",\n  \"role\": \"DONOR\"\n}"
            }
          }
        },
        {
          "name": "Register Volunteer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Volunteer Sam\",\n  \"email\": \"volunteer@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543211\",\n  \"address\": \"Chennai, Tamil Nadu\",\n  \"role\": \"VOLUNTEER\"\n}"
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@ngo.com\",\n  \"password\": \"admin123\",\n  \"phone\": \"9000000001\",\n  \"address\": \"NGO HQ, Chennai\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  console.log('Token saved:', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "NGOs",
      "item": [
        {
          "name": "Get All NGOs",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/ngos", "host": ["{{baseUrl}}"], "path": ["api","ngos"] }
          }
        },
        {
          "name": "Search NGOs by Location",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/ngos?location=Chennai",
              "host": ["{{baseUrl}}"], "path": ["api","ngos"],
              "query": [{ "key": "location", "value": "Chennai" }]
            }
          }
        },
        {
          "name": "Get NGO by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/ngos/1", "host": ["{{baseUrl}}"], "path": ["api","ngos","1"] }
          }
        },
        {
          "name": "Create NGO (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/ngos", "host": ["{{baseUrl}}"], "path": ["api","ngos"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Hope Foundation\",\n  \"description\": \"NGO helping underprivileged communities\",\n  \"address\": \"Chennai, Tamil Nadu\",\n  \"contactEmail\": \"hope@ngo.org\",\n  \"contactPhone\": \"9000000000\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Campaigns",
      "item": [
        {
          "name": "Get All Campaigns",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/campaigns", "host": ["{{baseUrl}}"], "path": ["api","campaigns"] }
          }
        },
        {
          "name": "Get Campaign by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/campaigns/1", "host": ["{{baseUrl}}"], "path": ["api","campaigns","1"] }
          }
        },
        {
          "name": "Create Campaign",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/campaigns", "host": ["{{baseUrl}}"], "path": ["api","campaigns"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Winter Clothes Drive\",\n  \"description\": \"Collecting warm clothes for the homeless\",\n  \"donationType\": \"CLOTHES\",\n  \"targetAmount\": 50000,\n  \"startDate\": \"2025-01-01\",\n  \"endDate\": \"2025-03-31\",\n  \"ngoId\": 1\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Donations",
      "item": [
        {
          "name": "Donate Money",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/donations/money", "host": ["{{baseUrl}}"], "path": ["api","donations","money"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"donorId\": 1,\n  \"campaignId\": 1,\n  \"donationType\": \"MONEY\",\n  \"amount\": 500.00\n}"
            }
          }
        },
        {
          "name": "Donate Goods",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/donations/goods", "host": ["{{baseUrl}}"], "path": ["api","donations","goods"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"donorId\": 1,\n  \"campaignId\": 1,\n  \"donationType\": \"CLOTHES\",\n  \"itemDescription\": \"10 winter jackets, 5 sweaters, good condition\"\n}"
            }
          }
        },
        {
          "name": "Get Donation History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/donations/history/1", "host": ["{{baseUrl}}"], "path": ["api","donations","history","1"] }
          }
        }
      ]
    },
    {
      "name": "Pickups",
      "item": [
        {
          "name": "Request Pickup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/pickups/request", "host": ["{{baseUrl}}"], "path": ["api","pickups","request"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"donorId\": 1,\n  \"donationId\": 1,\n  \"pickupAddress\": \"123 Main Street, Chennai\",\n  \"pickupTime\": \"2025-02-15T10:00:00\"\n}"
            }
          }
        },
        {
          "name": "Get Pickups by Donor",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/pickups/1", "host": ["{{baseUrl}}"], "path": ["api","pickups","1"] }
          }
        }
      ]
    },
    {
      "name": "Volunteer Tasks",
      "item": [
        {
          "name": "Get Tasks by Volunteer",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/tasks/volunteer/2", "host": ["{{baseUrl}}"], "path": ["api","tasks","volunteer","2"] }
          }
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tasks/updateStatus/1", "host": ["{{baseUrl}}"], "path": ["api","tasks","updateStatus","1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Approve Campaign",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/admin/campaign/approve", "host": ["{{baseUrl}}"], "path": ["api","admin","campaign","approve"] },
            "body": { "mode": "raw", "raw": "{\n  \"campaignId\": 1\n}" }
          }
        },
        {
          "name": "Reject Campaign",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/admin/campaign/reject", "host": ["{{baseUrl}}"], "path": ["api","admin","campaign","reject"] },
            "body": { "mode": "raw", "raw": "{\n  \"campaignId\": 2\n}" }
          }
        },
        {
          "name": "Create Urgent Need",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/admin/urgent-need", "host": ["{{baseUrl}}"], "path": ["api","admin","urgent-need"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"URGENT: Flood Relief Needed\",\n  \"description\": \"Heavy rains in North Chennai — blankets and food required immediately.\",\n  \"createdByAdminId\": 3\n}"
            }
          }
        },
        {
          "name": "Get All Urgent Needs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/urgent-needs", "host": ["{{baseUrl}}"], "path": ["api","admin","urgent-needs"] }
          }
        },
        {
          "name": "Generate Report",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/reports/generate?type=MONTHLY_SUMMARY",
              "host": ["{{baseUrl}}"], "path": ["api","admin","reports","generate"],
              "query": [{ "key": "type", "value": "MONTHLY_SUMMARY" }]
            }
          }
        },
        {
          "name": "Get All Reports",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/reports", "host": ["{{baseUrl}}"], "path": ["api","admin","reports"] }
          }
        },
        {
          "name": "Get All Donors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/donors", "host": ["{{baseUrl}}"], "path": ["api","admin","donors"] }
          }
        },
        {
          "name": "Get All Volunteers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/volunteers", "host": ["{{baseUrl}}"], "path": ["api","admin","volunteers"] }
          }
        }
      ]
    }
  ]
}
